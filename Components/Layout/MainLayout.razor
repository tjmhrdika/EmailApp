@inherits LayoutComponentBase

<div style="display:flex;flex-direction:column;height:100vh;overflow:hidden;background:#f4f6f9;font-family:'Segoe UI',sans-serif;">

    <div style="
        height:70px;
        display:flex;
        align-items:center;
        justify-content:center;
        background:white;
        border-bottom:1px solid #ddd;
        flex-shrink:0;
        margin-left:240px;
    ">
        <img src="/logo-w-caption.png" style="height:40px;" />
    </div>

    <div style="display:flex;flex:1;overflow:hidden;">

        <div style="width:240px;flex-shrink:0;">
            <NavMenu />
        </div>

        <div style="flex:1;overflow:auto;">
            <div style="padding:32px;">
                @Body
            </div>
        </div>

    </div>

</div>