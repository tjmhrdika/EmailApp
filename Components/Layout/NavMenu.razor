@using System.IdentityModel.Tokens.Jwt
@using System.Security.Claims

<div style="width:240px;height:100vh;background:#ffffff;border-right:1px solid #e8eaed;display:flex;flex-direction:column;position:fixed;top:0;left:0;">

    <div style="padding:20px 20px 16px 20px;display:flex;align-items:center;gap:10px;border-bottom:1px solid #f0f0f0;">
        <div style="width:32px;height:32px;background:#1a73e8;border-radius:8px;display:flex;align-items:center;justify-content:center;">
            <i class="bi bi-envelope-fill" style="color:white;font-size:15px;"></i>
        </div>
        <span style="font-size:17px;font-weight:700;color:#1a1a2e;letter-spacing:-0.3px;">AlarmEmailApp</span>
    </div>

    <div style="padding:12px 12px 0 12px;">
        <div style="display:flex;align-items:center;background:#f4f6f9;border-radius:8px;padding:8px 12px;gap:8px;">
            <i class="bi bi-search" style="color:#9aa0ab;font-size:13px;"></i>
            <span style="font-size:13px;color:#9aa0ab;">Search</span>
        </div>
    </div>

    <div style="flex:1;padding:8px 12px;overflow-y:auto;margin-top:8px;">
        @NavItem("", "bi-house-door", "Home", true)
        @if (isLoggedIn)
        {
            @NavItem("users", "bi-people", "Users")
            @NavItem("emails", "bi-at", "Emails")
            @if (isAdmin)
            {
                @NavItem("send-email", "bi-send", "Send Email")
            }   
        }
    </div>

    <div style="padding:16px 12px;border-top:1px solid #f0f0f0;">
        <div style="display:flex;align-items:center;gap:10px;padding:8px;border-radius:8px;">
            <div style="width:34px;height:34px;background:linear-gradient(135deg,#667eea,#764ba2);border-radius:50%;display:flex;align-items:center;justify-content:center;">
                <i class="bi bi-person-fill" style="color:white;font-size:15px;"></i>
            </div>
            <div>
                <div style="font-size:13px;font-weight:600;color:#1a1a2e;">Admin</div>
                <div style="font-size:11px;color:#9aa0ab;">Administrator</div>
            </div>
        </div>
        <div style="margin-top:4px;">
            <a href="settings" style="display:flex;align-items:center;gap:10px;padding:9px 10px;border-radius:8px;text-decoration:none;color:#5f6368;font-size:13px;">
                <i class="bi bi-gear" style="font-size:15px;width:18px;"></i>
                Settings
            </a>
            @if (isLoggedIn)
            {
                <a href="" @onclick="Logout" style="display:flex;align-items:center;gap:10px;padding:9px 10px;border-radius:8px;text-decoration:none;color:#5f6368;font-size:13px;">
                    <i class="bi bi-box-arrow-right" style="font-size:15px;width:18px;"></i>
                    Log out
                </a>
            }
        </div>
    </div>

</div>

@code {
    bool isLoggedIn = false;
    bool isAdmin = false;

    RenderFragment NavItem(string href, string icon, string text, bool matchAll = false, bool isAlert = false) => builder =>
    {
        var i = 0;

        builder.OpenComponent<NavLink>(i++);
        builder.AddAttribute(i++, "href", href);
        if (matchAll)
            builder.AddAttribute(i++, "Match", NavLinkMatch.All);
        builder.AddAttribute(i++, "ActiveClass", "nav-active");
        builder.AddAttribute(i++, "style", $"display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:8px;text-decoration:none;color:{(isAlert ? "#e53935" : "#5f6368")};font-size:13.5px;font-weight:500;margin-bottom:2px;transition:background 0.15s;");

        builder.AddAttribute(i++, "ChildContent", (RenderFragment)(b =>
        {
            var j = 0;
            b.OpenElement(j++, "i");
            b.AddAttribute(j++, "class", $"bi {icon}");
            b.AddAttribute(j++, "style", $"font-size:16px;width:18px;color:{(isAlert ? "#e53935" : "#5f6368")};");
            b.CloseElement();
            b.AddContent(j++, text);
        }));

        builder.CloseComponent();
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var token = await JS.InvokeAsync<string>("localStorage.getItem", "authToken");
        if (string.IsNullOrEmpty(token)) return;
        isLoggedIn = true;
        StateHasChanged();

        JwtSecurityTokenHandler? handler = new JwtSecurityTokenHandler();
        JwtSecurityToken? jwt = handler.ReadJwtToken(token);
        string? role = jwt.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Role)?.Value;
        if (role == "Admin")
        {
            isAdmin = true;
            StateHasChanged();
        }
    }

    async Task Logout()
    {
        await JS.InvokeVoidAsync("localStorage.removeItem", "authToken");
        NavigationManager.NavigateTo("/", true);
    }
}