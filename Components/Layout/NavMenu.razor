@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthProvider

<div style="width:256px;height:100vh;background:#ffffff;border-right:1px solid #e8eaed;display:flex;flex-direction:column;position:fixed;top:0;left:0;">

    <div style="padding:12px 16px;border-bottom:1px solid #f0f0f0;display:flex;align-items:center;justify-content:space-between;">
        <img src="/img/logo_agatos.png" style="height:32px;object-fit:contain;display:block;" />
        <button id="sidebar-close-btn"
                style="display:none;align-items:center;justify-content:center;width:32px;height:32px;background:none;border:1px solid #e8eaed;border-radius:7px;cursor:pointer;color:#5f6368;"
                @onclick="OnClose">
            <i class="bi bi-x" style="font-size:17px;"></i>
        </button>
    </div>

    @* <div style="padding:10px 12px 0 12px;">
        <div style="display:flex;align-items:center;background:#f4f6f9;border-radius:8px;padding:8px 12px;gap:8px;">
            <i class="bi bi-search" style="color:#9aa0ab;font-size:13px;"></i>
            <span style="font-size:13px;color:#9aa0ab;">Search</span>
        </div>
    </div> *@

    <div style="flex:1;padding:8px 12px;overflow-y:auto;margin-top:6px;">
        @NavItem("", "bi-house-door", "Home", true)

        @if (isAdmin)
        {
            @NavItem("users", "bi-people", "Users")
            @NavItem("emails", "bi-at", "Emails", false, true)
            @NavItem("send-email", "bi-send", "Send Email")
        }
    </div>

    <div style="padding:14px 12px;border-top:1px solid #f0f0f0;">
        <div style="display:flex;align-items:center;gap:10px;padding:8px;border-radius:8px;">
            <div style="width:34px;height:34px;background:#e8eaed;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <i class="bi bi-person-fill" style="color:#5f6368;font-size:15px;"></i>
            </div>
            <div>
                <div style="font-size:13px;font-weight:600;color:#1a1a2e;">@username</div>
                <div style="font-size:11px;color:#9aa0ab;">@(isAdmin ? "Administrator" : "User")</div>
            </div>
        </div>
        <div style="margin-top:2px;">
            <button @onclick="Logout"
                    style="width:100%;display:flex;align-items:center;gap:10px;padding:9px 10px;border-radius:8px;color:#5f6368;font-size:13px;background:none;border:none;cursor:pointer;">
                <i class="bi bi-box-arrow-right" style="font-size:15px;width:18px;"></i>
                Log out
            </button>
        </div>
    </div>

</div>

@code {
    [Parameter] public EventCallback OnClose { get; set; }
    [CascadingParameter] private Task<AuthenticationState>? AuthStateTask { get; set; }

    private bool isAdmin = false;
    private string username = "User";

    protected override async Task OnInitializedAsync()
    {
        if (AuthStateTask is null) return;

        var authState = await AuthStateTask;
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            isAdmin = user.IsInRole("Admin");
            username = user.Identity.Name ?? "User";
        }
    }

    private async Task Logout()
    {
        await JS.InvokeVoidAsync("localStorage.removeItem", "authToken");

        if (AuthProvider is CustomAuthenticationStateProvider customProvider)
            customProvider.NotifyUserLogout();

        NavigationManager.NavigateTo("/login", true);
    }

    RenderFragment NavItem(string href, string icon, string text, bool matchAll = false, bool isAlert = false) => builder =>
    {
        var i = 0;
        builder.OpenComponent<NavLink>(i++);
        builder.AddAttribute(i++, "href", href);
        if (matchAll)
            builder.AddAttribute(i++, "Match", NavLinkMatch.All);
        builder.AddAttribute(i++, "ActiveClass", "nav-active");
        builder.AddAttribute(i++, "style",
            $"display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:8px;text-decoration:none;color:{(isAlert ? "#e53935" : "#5f6368")};font-size:13.5px;font-weight:500;margin-bottom:2px;");
        builder.AddAttribute(i++, "ChildContent", (RenderFragment)(b =>
        {
            var j = 0;
            b.OpenElement(j++, "i");
            b.AddAttribute(j++, "class", $"bi {icon}");
            b.AddAttribute(j++, "style", $"font-size:16px;width:18px;color:{(isAlert ? "#e53935" : "#5f6368")};");
            b.CloseElement();
            b.AddContent(j++, text);
        }));
        builder.CloseComponent();
    };
}