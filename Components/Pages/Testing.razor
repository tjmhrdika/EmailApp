@page "/send-email"
@using EmailApp.Models
@using EmailApp.Data
@using EmailApp.Services
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AlarmDbContext> AlarmDbFactory
@inject IDbContextFactory<AppDbContext> AppDbFactory
@inject IEmailService EmailService

<div style="max-width:900px;">
    <div style="margin-bottom:28px;">
        <h2 style="font-size:22px;font-weight:700;color:#1a1a2e;margin:0 0 4px 0;">Testing</h2>
        <p style="font-size:13px;color:#9aa0ab;margin:0;">Insert alarm manual ke database dan kirim email notifikasi</p>
    </div>

    @if (!string.IsNullOrEmpty(Message))
    {
        <div style="display:flex;align-items:center;gap:8px;padding:12px 16px;border-radius:8px;margin-bottom:20px;font-size:13px;font-weight:500;background:@(IsError ? "#fff0f0" : "#f0fdf4");color:@(IsError ? "#e53935" : "#15803d");border:1px solid @(IsError ? "#ffd6d6" : "#bbf7d0");">
            <i class="bi bi-@(IsError ? "exclamation-circle" : "check-circle")" style="font-size:15px;"></i>
            @Message
        </div>
    }

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">
        <div style="background:#ffffff;border-radius:12px;border:1px solid #e8eaed;padding:24px;">
            <h5 style="font-size:15px;font-weight:600;color:#1a1a2e;margin:0 0 20px 0;">Manual Insert</h5>
            <div style="display:grid;gap:16px;margin-bottom:20px;">
                <div>
                    <label style="display:block;font-size:12px;font-weight:600;color:#5f6368;margin-bottom:6px;text-transform:uppercase;letter-spacing:0.5px;">Alarm ID</label>
                    <input @bind="AlarmId" type="number" style="width:100%;padding:10px 12px;border:1px solid #e8eaed;border-radius:8px;font-size:14px;color:#1a1a2e;outline:none;box-sizing:border-box;" />
                </div>
                <div>
                    <label style="display:block;font-size:12px;font-weight:600;color:#5f6368;margin-bottom:6px;text-transform:uppercase;letter-spacing:0.5px;">Alarm State</label>
                    <select @bind="AlarmState" style="width:100%;padding:10px 12px;border:1px solid #e8eaed;border-radius:8px;font-size:14px;color:#1a1a2e;outline:none;background:#fff;box-sizing:border-box;">
                        <option value="UNACK_ALM">UNACK_ALM (Unacknowledged)</option>
                        <option value="ACTIVE">ACTIVE</option>
                        <option value="ACK">ACK (Acknowledged)</option>
                        <option value="RETURN">RETURN</option>
                    </select>
                </div>
                <div>
                    <label style="display:block;font-size:12px;font-weight:600;color:#5f6368;margin-bottom:6px;text-transform:uppercase;letter-spacing:0.5px;">Priority</label>
                    <input @bind="Priority" type="number" style="width:100%;padding:10px 12px;border:1px solid #e8eaed;border-radius:8px;font-size:14px;color:#1a1a2e;outline:none;box-sizing:border-box;" />
                </div>
            </div>
            <div style="display:flex;gap:10px;">
                <button @onclick="InsertAndSend" disabled="@IsLoading"
                        style="flex:1;display:flex;align-items:center;justify-content:center;gap:8px;padding:10px 16px;background:#1a73e8;color:white;border:none;border-radius:8px;font-size:14px;font-weight:600;cursor:pointer;opacity:@(IsLoading ? "0.6" : "1");">
                    <i class="bi bi-send" style="font-size:14px;"></i>
                    @(IsLoading ? "Processing..." : "Insert & Send")
                </button>
                <button @onclick="SendToAllEmails" disabled="@IsLoading"
                        style="display:flex;align-items:center;gap:8px;padding:10px 16px;background:#34a853;color:white;border:none;border-radius:8px;font-size:14px;font-weight:600;cursor:pointer;opacity:@(IsLoading ? "0.6" : "1");">
                    <i class="bi bi-envelope-check" style="font-size:14px;"></i>
                    Send All
                </button>
            </div>
        </div>

        <div style="background:#ffffff;border-radius:12px;border:1px solid #e8eaed;padding:24px;">
            <h5 style="font-size:15px;font-weight:600;color:#1a1a2e;margin:0 0 20px 0;">Quick Actions</h5>
            <div style="display:flex;flex-direction:column;gap:8px;">
                <button @onclick="() => InsertPreset(85)" style="display:flex;align-items:center;gap:10px;padding:10px 14px;background:#f4f6f9;border:1px solid #e8eaed;border-radius:8px;font-size:13px;color:#1a1a2e;font-weight:500;cursor:pointer;text-align:left;">
                    <i class="bi bi-lightning-charge" style="color:#f59e0b;font-size:14px;"></i>
                    Alarm 85 - Pump5807
                </button>
                <button @onclick="() => InsertPreset(83)" style="display:flex;align-items:center;gap:10px;padding:10px 14px;background:#f4f6f9;border:1px solid #e8eaed;border-radius:8px;font-size:13px;color:#1a1a2e;font-weight:500;cursor:pointer;text-align:left;">
                    <i class="bi bi-lightning-charge" style="color:#f59e0b;font-size:14px;"></i>
                    Alarm 83 - Pump5707
                </button>
                <button @onclick="() => InsertPreset(84)" style="display:flex;align-items:center;gap:10px;padding:10px 14px;background:#f4f6f9;border:1px solid #e8eaed;border-radius:8px;font-size:13px;color:#1a1a2e;font-weight:500;cursor:pointer;text-align:left;">
                    <i class="bi bi-lightning-charge" style="color:#f59e0b;font-size:14px;"></i>
                    Alarm 84 - Pump5793
                </button>
                <button @onclick="() => InsertPreset(70)" style="display:flex;align-items:center;gap:10px;padding:10px 14px;background:#f4f6f9;border:1px solid #e8eaed;border-radius:8px;font-size:13px;color:#1a1a2e;font-weight:500;cursor:pointer;text-align:left;">
                    <i class="bi bi-lightning-charge" style="color:#f59e0b;font-size:14px;"></i>
                    Alarm 70 - Pump1214
                </button>
            </div>
        </div>
    </div>

    <div style="background:#fff;border-radius:12px;border:1px solid #e8eaed;overflow:hidden;">
        <div style="padding:20px 24px;border-bottom:1px solid #f0f0f0;display:flex;align-items:center;justify-content:space-between;">
            <h5 style="font-size:15px;font-weight:600;color:#1a1a2e;margin:0;">Recent Alarms</h5>
            <span style="font-size:12px;color:#9aa0ab;background:#f4f6f9;padding:4px 10px;border-radius:20px;">Last 10</span>
        </div>
        <div style="overflow-x:auto;">
            <table style="width:100%;border-collapse:collapse;font-size:13px;">
                <thead>
                    <tr style="background:#f8fafc;">
                        <th style="padding:12px 16px;text-align:left;font-size:11px;font-weight:700;color:#9aa0ab;text-transform:uppercase;letter-spacing:0.5px;">Time</th>
                        <th style="padding:12px 16px;text-align:left;font-size:11px;font-weight:700;color:#9aa0ab;text-transform:uppercase;letter-spacing:0.5px;">State</th>
                        <th style="padding:12px 16px;text-align:left;font-size:11px;font-weight:700;color:#9aa0ab;text-transform:uppercase;letter-spacing:0.5px;">Tag</th>
                        <th style="padding:12px 16px;text-align:left;font-size:11px;font-weight:700;color:#9aa0ab;text-transform:uppercase;letter-spacing:0.5px;">Priority</th>
                    </tr>
                </thead>
                <tbody>
                    @if (recentAlarms.Any())
                    {
                        foreach (var alarm in recentAlarms)
                        {
                            <tr style="border-top:1px solid #f0f0f0;">
                                <td style="padding:12px 16px;color:#5f6368;">@alarm.EventStamp.ToString("HH:mm:ss")</td>
                                <td style="padding:12px 16px;">
                                    <span style="background:@(alarm.AlarmState == "UNACK_ALM" ? "#fee2e2" : "#f4f6f9");color:@(alarm.AlarmState == "UNACK_ALM" ? "#dc2626" : "#5f6368");padding:3px 8px;border-radius:4px;font-size:11px;font-weight:600;">
                                        @alarm.AlarmState
                                    </span>
                                </td>
                                <td style="padding:12px 16px;color:#1a1a2e;font-weight:500;">@alarm.TagName</td>
                                <td style="padding:12px 16px;color:@(alarm.Priority == 500 ? "#f59e0b" : "#1a1a2e");font-weight:@(alarm.Priority == 500 ? "700" : "400");">@alarm.Priority</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" style="padding:24px;text-align:center;color:#9aa0ab;font-size:13px;">No alarms found</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private int AlarmId = 85;
    private string AlarmState = "UNACK_ALM";
    private int Priority = 500;
    private string Message = string.Empty;
    private bool IsError = false;
    private bool IsLoading = false;
    private List<RecentAlarm> recentAlarms = new();

    private class RecentAlarm
    {
        public DateTime EventStamp { get; set; }
        public string AlarmState { get; set; } = string.Empty;
        public string TagName { get; set; } = string.Empty;
        public int Priority { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadRecentAlarms();
    }

    private async Task LoadRecentAlarms()
    {
        await using var db = await AlarmDbFactory.CreateDbContextAsync();

        recentAlarms = await db.AlarmDetails
            .Include(ad => ad.AlarmMaster)
            .OrderByDescending(ad => ad.EventStamp)
            .Take(10)
            .Select(ad => new RecentAlarm
            {
                EventStamp = ad.EventStamp,
                AlarmState = ad.AlarmState,
                TagName = ad.AlarmMaster.TagName,
                Priority = ad.AlarmMaster.Priority
            })
            .ToListAsync();
    }

    private async Task InsertPreset(int alarmId)
    {
        AlarmId = alarmId;
        AlarmState = "UNACK_ALM";
        Priority = 500;
        await InsertAndSend();
    }

    private async Task InsertAndSend()
    {
        IsLoading = true;
        Message = string.Empty;
        IsError = false;
        StateHasChanged();

        try
        {
            await using var alarmDb = await AlarmDbFactory.CreateDbContextAsync();

            var now = DateTime.UtcNow;

            var alarmDetail = new AlarmDetail
            {
                AlarmId = AlarmId,
                AlarmState = AlarmState,
                Priority = (short)Priority,
                AlarmTransition = "ALM",
                AlarmType = "DSC   ",
                TransitionTime = DateTime.Now,  // ganti UtcNow → Now
                TransitionTimeFracSec = 0,
                TransitionTimeZoneOffset = 420,
                TransitionDaylightAdjustment = 0,
                OperatorName = "System",
                OperatorNode = "TEST"
                // hapus EventStamp karena computed column
            };

            await alarmDb.AlarmDetails.AddAsync(alarmDetail);
            await alarmDb.SaveChangesAsync();

            await using var appDb = await AppDbFactory.CreateDbContextAsync();
            var recipients = await appDb.Emails.Select(e => e.Address).ToListAsync();

            var alarmMaster = await alarmDb.AlarmMasters.FirstOrDefaultAsync(am => am.AlarmId == AlarmId);
            var tagName = alarmMaster?.TagName ?? $"Alarm_{AlarmId}";
            var groupName = alarmMaster?.GroupName ?? "Unknown";

            var subject = $"[TEST] {tagName} - Priority {Priority}";
            var body = $@"
TEST ALARM NOTIFICATION
======================
Tag: {tagName}
Group: {groupName}
Priority: {Priority}
Time: {now:yyyy-MM-dd HH:mm:ss}
State: {AlarmState}

This is a test alarm from Testing Page.
";

            if (recipients.Any())
            {
                await EmailService.SendBulkEmailAsync(recipients, subject, body);
                Message = $"✓ Alarm inserted and email sent to {recipients.Count} recipient(s)";
            }
            else
            {
                Message = "✓ Alarm inserted but no email recipients found";
            }

            await LoadRecentAlarms();
        }
        catch (Exception ex)
        {
            IsError = true;
            Message = $"✗ Error: {ex.InnerException?.Message ?? ex.Message}";
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private async Task SendToAllEmails()
    {
        IsLoading = true;
        Message = string.Empty;
        IsError = false;
        StateHasChanged();

        try
        {
            await using var appDb = await AppDbFactory.CreateDbContextAsync();
            var recipients = await appDb.Emails.Select(e => e.Address).ToListAsync();

            if (!recipients.Any())
            {
                Message = "No email recipients found";
                IsError = true;
                return;
            }

            var subject = "[TEST] Manual Email Test";
            var body = $@"
MANUAL TEST EMAIL
================
This is a manual test email sent from Testing Page.
Time: {DateTime.UtcNow:yyyy-MM-dd HH:mm:ss}

If you receive this, the email service is working correctly.
";

            await EmailService.SendBulkEmailAsync(recipients, subject, body);
            Message = $"✓ Test email sent to {recipients.Count} recipient(s)";
        }
        catch (Exception ex)
        {
            IsError = true;
            Message = $"✗ Error: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }
}
