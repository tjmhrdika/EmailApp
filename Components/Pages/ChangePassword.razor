@page "/change-password"
@using EmailApp.Data
@using EmailApp.Models
@using Microsoft.EntityFrameworkCore
@using System.ComponentModel.DataAnnotations
@using System.IdentityModel.Tokens.Jwt
@inject IJSRuntime JS
@inject IDbContextFactory<AppDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Change Password</PageTitle>

<div style="max-width:520px;padding:20px;">
    <div style="margin-bottom:24px;">
        <h1 style="font-size:24px;font-weight:700;color:#0d1b2a;margin:0;">Change Password</h1>
        <p style="font-size:13px;color:#6b7a8d;margin-top:4px;">Update your account password</p>
    </div>

    @if (!string.IsNullOrEmpty(alertMessage))
    {
        <div style="margin-bottom:20px;padding:12px 16px;border-radius:8px;background:@(alertType == "success" ? "#d4edda" : "#fee2e2");border:1px solid @(alertType == "success" ? "#c3e6cb" : "#fecaca");color:@(alertType == "success" ? "#155724" : "#dc2626");font-size:13px;display:flex;align-items:center;justify-content:space-between;">
            @alertMessage
            <button type="button" @onclick="() => alertMessage = string.Empty" style="background:none;border:none;font-size:20px;cursor:pointer;color:@(alertType == "success" ? "#155724" : "#dc2626");">&times;</button>
        </div>
    }

    <div style="background:#ffffff;border-radius:12px;border:1px solid #e2e8f0;padding:24px;box-shadow:0 1px 4px rgba(0,0,0,0.05);">
        <EditForm Model="changePasswordModel" OnValidSubmit="HandleChangePassword">
            <DataAnnotationsValidator />

            <div style="margin-bottom:20px;">
                <label style="font-size:13px;font-weight:600;color:#0d1b2a;margin-bottom:6px;display:block;">Current Password</label>
                <InputText type="password" @bind-Value="changePasswordModel.CurrentPassword" 
                           style="width:100%;padding:10px 12px;border:1px solid #e2e8f0;border-radius:8px;font-size:13px;background:#f8fafc;outline:none;" />
                <ValidationMessage For="@(() => changePasswordModel.CurrentPassword)" style="font-size:11px;color:#dc2626;margin-top:4px;display:block;" />
            </div>

            <div style="margin-bottom:20px;">
                <label style="font-size:13px;font-weight:600;color:#0d1b2a;margin-bottom:6px;display:block;">New Password</label>
                <InputText type="password" @bind-Value="changePasswordModel.NewPassword" 
                           style="width:100%;padding:10px 12px;border:1px solid #e2e8f0;border-radius:8px;font-size:13px;background:#f8fafc;outline:none;" />
                <ValidationMessage For="@(() => changePasswordModel.NewPassword)" style="font-size:11px;color:#dc2626;margin-top:4px;display:block;" />
            </div>

            <div style="margin-bottom:24px;">
                <label style="font-size:13px;font-weight:600;color:#0d1b2a;margin-bottom:6px;display:block;">Confirm New Password</label>
                <InputText type="password" @bind-Value="changePasswordModel.ConfirmPassword" 
                           style="width:100%;padding:10px 12px;border:1px solid #e2e8f0;border-radius:8px;font-size:13px;background:#f8fafc;outline:none;" />
                <ValidationMessage For="@(() => changePasswordModel.ConfirmPassword)" style="font-size:11px;color:#dc2626;margin-top:4px;display:block;" />
            </div>

            <div style="display:flex;gap:12px;justify-content:flex-end;">
                <button type="submit" 
                        style="display:flex;align-items:center;gap:6px;padding:10px 16px;background:#1a73e8;border:none;border-radius:8px;font-size:13px;font-weight:600;color:white;cursor:pointer;">
                    <i class="bi bi-check-lg"></i>
                    Update Password
                </button>
            </div>
        </EditForm>
    </div>
</div>

@code {
    private ChangePasswordModel changePasswordModel = new();
    private string alertMessage = string.Empty;
    private string alertType = "error";
    private Guid userId;
    private bool isLoading = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            string? token = await JS.InvokeAsync<string>("localStorage.getItem", "authToken");
            if (string.IsNullOrEmpty(token))
            {
                NavigationManager.NavigateTo("/");
                return;
            }

            JwtSecurityTokenHandler? handler = new JwtSecurityTokenHandler();
            JwtSecurityToken? jwt = handler.ReadJwtToken(token);
            var userIdClaim = jwt.Claims.FirstOrDefault(c => c.Type == JwtRegisteredClaimNames.Sub);
            if (userIdClaim != null && Guid.TryParse(userIdClaim.Value, out Guid id))
            {
                userId = id;
            }
            else
            {
                NavigationManager.NavigateTo("/login");
            }
        }
    }

    private async Task HandleChangePassword()
    {
        try
        {
            using var db = await DbFactory.CreateDbContextAsync();
            
            // Get user from database
            var user = await db.Users.FirstOrDefaultAsync(u => u.Id == userId);
            
            if (user == null)
            {
                alertType = "error";
                alertMessage = "User not found. Please login again.";
                StateHasChanged();
                await Task.Delay(2000);
                NavigationManager.NavigateTo("/login");
                return;
            }

            // Verify current password using BCrypt
            if (!BCrypt.Net.BCrypt.Verify(changePasswordModel.CurrentPassword, user.Password))
            {
                alertType = "error";
                alertMessage = "Current password is incorrect.";
                StateHasChanged();
                return;
            }

            // Hash new password
            user.Password = BCrypt.Net.BCrypt.HashPassword(changePasswordModel.NewPassword);
            
            // Save changes to database
            db.Users.Update(user);
            await db.SaveChangesAsync();
            
            alertType = "success";
            alertMessage = "Password changed successfully!";
            changePasswordModel = new ChangePasswordModel();
            StateHasChanged();
            
            // Optional: Redirect after 2 seconds
            await Task.Delay(2000);
            @* Navigation.NavigateTo("/"); *@
        }
        catch (Exception ex)
        {
            alertType = "error";
            alertMessage = $"An error occurred: {ex.Message}";
            StateHasChanged();
        }
    }

    public class ChangePasswordModel
    {
        [Required(ErrorMessage = "Current password is required")]
        public string CurrentPassword { get; set; } = string.Empty;

        [Required(ErrorMessage = "New password is required")]
        [MinLength(8, ErrorMessage = "Password must be at least 8 characters")]
        public string NewPassword { get; set; } = string.Empty;

        [Required(ErrorMessage = "Please confirm your new password")]
        [Compare("NewPassword", ErrorMessage = "Passwords do not match")]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}