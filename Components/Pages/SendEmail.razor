@page "/send-email"
@using System.Net
@using System.Net.Mail
@using System.IdentityModel.Tokens.Jwt
@using System.Security.Claims
@using System.ComponentModel.DataAnnotations

@if (!string.IsNullOrEmpty(alertMessage))
{
    <div class="alert alert-@alertType alert-dismissible fade show" role="alert">
        @alertMessage
        <button type="button" class="btn-close" @onclick="() => alertMessage = String.Empty"></button>
    </div>
}

<EditForm Model="@form" OnValidSubmit="Send">
    <DataAnnotationsValidator />

    <div class="d-flex justify-content-center mt-5">
        <div class="card shadow-sm p-4" style="max-width: 600px; width: 100%;">

            <h3 class="mb-3">Send Email</h3>
            
            <div class="mb-3">
                <label class="form-label">SMTP</label>
                <InputText class="form-control" @bind-Value="form.SMTP" />
                <ValidationMessage For="@(() => form.SMTP)" />
            </div>

            <div class="mb-3">
                <label class="form-label">From Email Address</label>
                <InputText type="email" class="form-control" @bind-Value="form.FromEmail" />
                <ValidationMessage For="@(() => form.FromEmail)" />
            </div>

            <div class="mb-3">
                <label class="form-label">Password Email</label>
                <InputText type="password" class="form-control" @bind-Value="form.Password" />
                <ValidationMessage For="@(() => form.Password)" />
            </div>

            <div class="mb-3">
                <label class="form-label">To Email Address</label>
                <InputText type="email" class="form-control" @bind-Value="form.ToEmail" />
                <ValidationMessage For="@(() => form.ToEmail)" />
            </div>

            <div class="mb-3">
                <label class="form-label">Text</label>
                <InputTextArea class="form-control" rows="4" @bind-Value="form.Text" />
                <ValidationMessage For="@(() => form.Text)" />
            </div>

            <div class="d-flex justify-content-end">
                <button type="submit" class="btn btn-primary d-flex align-items-center gap-2">
                    <i class="bi bi-send"></i>
                    Send
                </button>
            </div>

        </div>
    </div>
</EditForm>

@code {
    class SendEmailModel
    {
        [Required]
        public string SMTP { get; set; } = String.Empty;
        [Required, EmailAddress]
        public string FromEmail { get; set; } = String.Empty;
        [Required]
        public string Password { get; set; } = String.Empty;
        [Required, EmailAddress]
        public string ToEmail { get; set; } = String.Empty;
        [Required]
        public string Text { get; set; } = String.Empty;
    }

    SendEmailModel form = new SendEmailModel();
    string alertMessage = String.Empty;
    string alertType = String.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            string? token = await JS.InvokeAsync<string>("localStorage.getItem", "authToken");
            if (string.IsNullOrEmpty(token))
            {
                NavigationManager.NavigateTo("/");
                return;
            }

            JwtSecurityTokenHandler? handler = new JwtSecurityTokenHandler();
            JwtSecurityToken? jwt = handler.ReadJwtToken(token);
            string? role = jwt.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Role)?.Value;
            if (role != "Admin")
            {
                NavigationManager.NavigateTo("/");
            }
        }
    }

    void Send()
    {
        try
        {
            SmtpClient? smtp = new SmtpClient(form.SMTP)
            {
                Port = 587,
                Credentials = new NetworkCredential(
                    form.FromEmail,
                    form.Password
                ),
                EnableSsl = true
            };

            MailMessage? mail = new MailMessage
            {
                From = new MailAddress(form.FromEmail),
                Subject = "Alarm Notification",
                Body = form.Text,
            };

            mail.To.Add(form.ToEmail);
            smtp.Send(mail);

            alertMessage = "Email sent!";
            alertType = "success";
        }
        catch (Exception ex)
        {
            alertMessage = ex.Message;
            alertType = "danger";
        }
    }
}