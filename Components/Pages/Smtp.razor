@page "/smtp"
@using System.Net
@using System.Net.Mail
@using System.IdentityModel.Tokens.Jwt
@using System.Security.Claims
@using System.ComponentModel.DataAnnotations

@if (!string.IsNullOrEmpty(alertMessage))
{
    <div class="alert alert-@alertType alert-dismissible fade show" role="alert">
        @alertMessage
        <button type="button" class="btn-close" @onclick="() => alertMessage = String.Empty"></button>
    </div>
}

<div class="container mt-5">
    <div class="row g-4">

        <!-- LEFT -->
        <div class="col-md-5">
            <div class="card shadow-sm p-4 h-100">
                <EditForm Model="@setSmtp" OnValidSubmit="Set">
                    <DataAnnotationsValidator />

                    <h3 class="mb-3">Set SMTP</h3>
            
                    <div class="mb-3">
                        <label class="form-label">SMTP</label>
                        <InputText class="form-control" disabled="@( !isEdit )" @bind-Value="setSmtp.Smtp" />
                        <ValidationMessage For="@(() => setSmtp.Smtp)" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <InputText type="email" class="form-control" disabled="@( !isEdit )" @bind-Value="setSmtp.Email" />
                        <ValidationMessage For="@(() => setSmtp.Email)" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <InputText type="password" class="form-control" disabled="@( !isEdit )" @bind-Value="setSmtp.Password" />
                        <ValidationMessage For="@(() => setSmtp.Password)" />
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        @if (isEdit)
                        {
                            <button type="submit" class="btn btn-success d-flex align-items-center gap-2">
                                <i class="bi bi-check-lg"></i>
                                OK
                            </button>

                            <button type="button"
                                    class="btn btn-secondary d-flex align-items-center gap-2"
                                    @onclick="CancelEdit">
                                <i class="bi bi-x"></i>
                                Cancel
                            </button>
                        }
                        else
                        {
                            <button type="button"
                                    class="btn btn-primary d-flex align-items-center gap-2"
                                    @onclick="BeginEdit">
                                <i class="bi bi-pencil"></i>
                                Edit
                            </button>
                        }
                    </div>
                </EditForm>
            </div>
        </div>

        <!-- RIGHT -->
        <div class="col-md-7">
            <div class="card shadow-sm p-4 h-100">
                <h3 class="mb-3">Test Email</h3>

                <div class="mb-3">
                    <label class="form-label">To Email</label>
                    <input type="email" class="form-control" @bind="toEmail" disabled=@(isEdit)>
                </div>

                <div class="mb-3">
                    <label class="form-label">Text</label>
                    <textarea type="email" class="form-control" rows="4" @bind="text" disabled=@(isEdit)></textarea>
                </div>

                <div class="d-flex justify-content-end">
                    <button type="submit" class="btn btn-primary d-flex align-items-center gap-2" @onclick=Send disabled=@(isEdit)>
                        <i class="bi bi-send"></i>
                        Send
                    </button>
                </div>
            </div>
        </div>

    </div>
</div>

@code {
    bool isEdit = false;
    SetSmtp setSmtp = new();
    SetSmtp tempSetSmtp = new();
    string toEmail = String.Empty;
    string text = String.Empty;
    string alertMessage = String.Empty;
    string alertType = String.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            string? token = await JS.InvokeAsync<string>("localStorage.getItem", "authToken");
            if (string.IsNullOrEmpty(token))
            {
                NavigationManager.NavigateTo("/");
                return;
            }

            JwtSecurityTokenHandler? handler = new JwtSecurityTokenHandler();
            JwtSecurityToken? jwt = handler.ReadJwtToken(token);
            string? role = jwt.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Role)?.Value;
            if (role != "Admin")
            {
                NavigationManager.NavigateTo("/");
            }
        }
    }

    protected override void OnInitialized()
    {
        setSmtp = db.SetSmtp.First();
    }

    async Task Set()
    {
        db.SetSmtp.Update(setSmtp);
        await db.SaveChangesAsync();
        isEdit = false;
    }

    void BeginEdit()
    {
        tempSetSmtp = setSmtp.Clone();
        isEdit = true;
    }

    void CancelEdit()
    {
        setSmtp = tempSetSmtp.Clone();
        isEdit = false;
    }

    void Send()
    {
        try
        {
            
            SmtpClient? smtp = new SmtpClient(setSmtp.Smtp)
            {
                Port = 587,
                Credentials = new NetworkCredential(
                    setSmtp.Email,
                    setSmtp.Password
                ),
                EnableSsl = true
            };

            MailMessage? mail = new MailMessage
            {
                From = new MailAddress(setSmtp.Email),
                Subject = "Alarm Notification",
                Body = text,
            };

            mail.To.Add(toEmail);
            smtp.Send(mail);

            alertMessage = "Email sent!";
            alertType = "success";
        }
        catch (Exception ex)
        {
            alertMessage = ex.Message;
            alertType = "danger";
        }
    }
}