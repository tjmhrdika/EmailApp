@page "/login"
@layout Components.Layout.EmptyLayout
@using EmailApp.Services
@using Microsoft.AspNetCore.Components.Forms
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthProvider

<div style="display:flex;justify-content:center;align-items:center;min-height:100vh;background:#f1f3f6;padding:16px;">
    <div style="background:#ffffff;border-radius:14px;border:1px solid #e8eaed;padding:36px 32px;width:100%;max-width:400px;">
        <div style="text-align:center;margin-bottom:28px;">
            <div style="width:44px;height:44px;background:#f0f4ff;border-radius:10px;display:flex;align-items:center;justify-content:center;margin:0 auto 14px auto;">
                <i class="bi bi-shield-lock" style="font-size:20px;color:#1a73e8;"></i>
            </div>
            <h2 style="font-size:20px;font-weight:700;color:#1a1a2e;margin:0 0 4px 0;">Selamat Datang</h2>
            <p style="font-size:13px;color:#9aa0ab;margin:0;">Masuk ke CIP Station</p>
        </div>

        <EditForm Model="loginModel" OnValidSubmit="LoginUser">
            <DataAnnotationsValidator />
            <div style="margin-bottom:16px;">
                <label style="display:block;font-size:12px;font-weight:600;color:#5f6368;margin-bottom:6px;text-transform:uppercase;letter-spacing:0.5px;">Username</label>
                <InputText @bind-Value="loginModel.Username"
                           style="width:100%;padding:10px 12px;border:1px solid #e8eaed;border-radius:8px;font-size:14px;color:#1a1a2e;outline:none;box-sizing:border-box;" />
                @if (!string.IsNullOrEmpty(usernameMessage))
                {
                    <span style="font-size:12px;color:#e53935;margin-top:4px;display:block;">@usernameMessage</span>
                }
            </div>

            <div style="margin-bottom:24px;">
                <label style="display:block;font-size:12px;font-weight:600;color:#5f6368;margin-bottom:6px;text-transform:uppercase;letter-spacing:0.5px;">Password</label>
                <InputText @bind-Value="loginModel.Password" type="password"
                           style="width:100%;padding:10px 12px;border:1px solid #e8eaed;border-radius:8px;font-size:14px;color:#1a1a2e;outline:none;box-sizing:border-box;" />
                @if (!string.IsNullOrEmpty(passwordMessage))
                {
                    <span style="font-size:12px;color:#e53935;margin-top:4px;display:block;">@passwordMessage</span>
                }
            </div>

            <button type="submit"
                    style="width:100%;padding:11px;background:#1a73e8;color:white;border:none;border-radius:8px;font-size:14px;font-weight:600;cursor:pointer;">
                Masuk
            </button>
        </EditForm>
    </div>
</div>

@code {
    private LoginRequest loginModel = new();
    private string usernameMessage = string.Empty;
    private string passwordMessage = string.Empty;

    private record LoginRequest
    {
        public string Username { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }

    private record TokenResponse(string token);

    private async Task LoginUser()
    {
        usernameMessage = string.Empty;
        passwordMessage = string.Empty;

        var response = await Http.PostAsJsonAsync("api/auth/login", loginModel);

        if (!response.IsSuccessStatusCode)
        {
            passwordMessage = "Username atau password salah";
            return;
        }

        var result = await response.Content.ReadFromJsonAsync<TokenResponse>();
        await JS.InvokeVoidAsync("localStorage.setItem", "authToken", result?.token);

        if (AuthProvider is CustomAuthenticationStateProvider customProvider)
            customProvider.NotifyUserAuthentication(result?.token ?? string.Empty);

        NavigationManager.NavigateTo("/", true);
    }
}