@page "/emails"
@page "/email-settings"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]
@using EmailApp.Models
@inject IEmailRecipientService EmailRecipientService
@inject ISmtpSettingsService SmtpSettingsService
@inject IEmailService EmailService

<PageTitle>Email Management</PageTitle>

<div style="width:100%;">
    <div style="width:100%;max-width:1600px;margin:0 auto;padding-right:24px;">
        <div style="margin-bottom:20px;display:flex;align-items:flex-start;justify-content:space-between;gap:16px;flex-wrap:wrap;">
            <div>
                <h1 style="font-size:22px;font-weight:800;color:#0d1b2a;margin:0;">Email Settings</h1>
                <p style="font-size:13px;color:#6b7a8d;margin:4px 0 0 0;">Kelola jalur notifikasi email dari satu tempat</p>
            </div>
            <button @onclick="LoadPageData" disabled="@isLoading" style="display:flex;align-items:center;gap:8px;padding:9px 14px;background:#ffffff;border:1px solid #d7dee8;border-radius:8px;color:#0d1b2a;font-size:13px;font-weight:600;cursor:pointer;opacity:@(isLoading ? 0.6 : 1);">
                <i class="bi bi-arrow-clockwise" style="font-size:14px;"></i>
                Refresh
            </button>
        </div>

        @if (!string.IsNullOrEmpty(message))
        {
            <div style="margin-bottom:20px;padding:12px 16px;border-radius:8px;background:@(messageType == "success" ? "#f0fdf4" : "#fff0f0");border:1px solid @(messageType == "success" ? "#bbf7d0" : "#ffd6d6");color:@(messageType == "success" ? "#15803d" : "#e53935");font-size:13px;display:flex;align-items:center;justify-content:space-between;">
                <span>@message</span>
                <button type="button" @onclick="ClearMessage" style="background:none;border:none;cursor:pointer;color:inherit;padding:0;display:flex;align-items:center;">
                    <i class="bi bi-x" style="font-size:17px;"></i>
                </button>
            </div>
        }

        <div style="display:grid;grid-template-columns:repeat(3,minmax(180px,1fr));gap:10px;margin-bottom:14px;">
            <div style="background:#ffffff;border-radius:8px;border:1px solid #e2e8f0;padding:12px 14px;">
                <div style="font-size:11px;font-weight:700;color:#6b7a8d;text-transform:uppercase;letter-spacing:0.6px;margin-bottom:6px;">Recipients</div>
                <div style="font-size:24px;font-weight:800;color:#0d1b2a;line-height:1;">@emails.Count</div>
            </div>
            <div style="background:#ffffff;border-radius:8px;border:1px solid #e2e8f0;padding:12px 14px;">
                <div style="font-size:11px;font-weight:700;color:#6b7a8d;text-transform:uppercase;letter-spacing:0.6px;margin-bottom:6px;">Groups</div>
                <div style="font-size:24px;font-weight:800;color:#0d1b2a;line-height:1;">@groups.Count</div>
            </div>
            <div style="background:#ffffff;border-radius:8px;border:1px solid @(IsSmtpConfigured ? "#bbf7d0" : "#fecaca");padding:12px 14px;">
                <div style="font-size:11px;font-weight:700;color:#6b7a8d;text-transform:uppercase;letter-spacing:0.6px;margin-bottom:6px;">SMTP</div>
                <div style="display:flex;align-items:center;gap:8px;">
                    <span style="width:9px;height:9px;border-radius:50%;background:@(IsSmtpConfigured ? "#16a34a" : "#dc2626");display:inline-block;"></span>
                    <span style="font-size:14px;font-weight:800;color:#0d1b2a;">@(IsSmtpConfigured ? "Configured" : "Incomplete")</span>
                    <span style="font-size:12px;color:#6b7a8d;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@smtpSettings.Host</span>
                </div>
            </div>
        </div>

        <div style="display:grid;grid-template-columns:minmax(420px,1fr) minmax(420px,1fr);gap:14px;margin-bottom:22px;">
            <div style="background:#ffffff;border-radius:8px;border:1px solid #d7dee8;padding:16px;box-shadow:0 1px 2px rgba(15,23,42,0.04);">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
                    <div>
                        <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;">
                            <i class="bi bi-hdd-network" style="font-size:15px;color:#1a73e8;"></i>
                            <div style="font-size:13px;font-weight:800;color:#0d1b2a;">SMTP Server</div>
                        </div>
                        <div style="font-size:13px;color:#6b7a8d;">Konfigurasi server pengirim email</div>
                    </div>
                    @if (!isEditingSmtp)
                    {
                        <button type="button" @onclick="BeginSmtpEdit" title="Edit SMTP" style="width:34px;height:34px;background:#1a73e8;border:none;border-radius:7px;color:white;display:flex;align-items:center;justify-content:center;cursor:pointer;">
                            <i class="bi bi-pencil"></i>
                        </button>
                    }
                </div>

                <EditForm Model="@smtpSettings" OnValidSubmit="SaveSmtpSettings">
                    <DataAnnotationsValidator />
                    <div style="display:grid;grid-template-columns:1fr 110px;gap:10px;">
                        <div>
                            <label style="font-size:12px;font-weight:600;color:#0d1b2a;margin-bottom:6px;display:block;">Host</label>
                            <InputText disabled="@(!isEditingSmtp)" @bind-Value="smtpSettings.Host" style="width:100%;padding:8px 10px;border:1px solid #d7dee8;border-radius:7px;font-size:13px;background:#f8fafc;outline:none;" />
                        </div>
                        <div>
                            <label style="font-size:12px;font-weight:600;color:#0d1b2a;margin-bottom:6px;display:block;">Port</label>
                            <InputNumber disabled="@(!isEditingSmtp)" @bind-Value="smtpSettings.Port" style="width:100%;padding:8px 10px;border:1px solid #d7dee8;border-radius:7px;font-size:13px;background:#f8fafc;outline:none;" />
                        </div>
                        <div>
                            <label style="font-size:12px;font-weight:600;color:#0d1b2a;margin-bottom:6px;display:block;">User</label>
                            <InputText type="email" disabled="@(!isEditingSmtp)" @bind-Value="smtpSettings.User" style="width:100%;padding:8px 10px;border:1px solid #d7dee8;border-radius:7px;font-size:13px;background:#f8fafc;outline:none;" />
                        </div>
                        <div>
                            <label style="font-size:12px;font-weight:600;color:#0d1b2a;margin-bottom:6px;display:block;">Password</label>
                            <InputText type="password" disabled="@(!isEditingSmtp)" @bind-Value="smtpSettings.Pass" style="width:100%;padding:8px 10px;border:1px solid #d7dee8;border-radius:7px;font-size:13px;background:#f8fafc;outline:none;" />
                        </div>
                        <div style="grid-column:1 / -1;">
                            <label style="font-size:12px;font-weight:600;color:#0d1b2a;margin-bottom:6px;display:block;">From Email</label>
                            <InputText type="email" disabled="@(!isEditingSmtp)" @bind-Value="smtpSettings.FromEmail" style="width:100%;padding:8px 10px;border:1px solid #d7dee8;border-radius:7px;font-size:13px;background:#f8fafc;outline:none;" />
                        </div>
                    </div>

                    @if (isEditingSmtp)
                    {
                        <div style="display:flex;justify-content:flex-end;gap:10px;margin-top:16px;">
                            <button type="button" @onclick="CancelSmtpEdit" style="display:flex;align-items:center;gap:6px;padding:9px 14px;background:#6c757d;border:none;border-radius:8px;font-size:13px;font-weight:600;color:white;cursor:pointer;">
                                <i class="bi bi-x"></i>
                                Cancel
                            </button>
                            <button type="submit" style="display:flex;align-items:center;gap:6px;padding:9px 14px;background:#1a73e8;border:none;border-radius:8px;font-size:13px;font-weight:600;color:white;cursor:pointer;">
                                <i class="bi bi-check-lg"></i>
                                Save
                            </button>
                        </div>
                    }
                </EditForm>
            </div>

            <div style="background:#ffffff;border-radius:8px;border:1px solid #d7dee8;padding:16px;box-shadow:0 1px 2px rgba(15,23,42,0.04);">
                <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;">
                    <i class="bi bi-send" style="font-size:15px;color:#1a73e8;"></i>
                    <div style="font-size:13px;font-weight:800;color:#0d1b2a;">Manual Email</div>
                </div>
                <div style="font-size:13px;color:#6b7a8d;margin-bottom:12px;">Kirim pesan manual ke @emails.Count penerima</div>

                <div style="display:grid;gap:12px;">
                    <div>
                        <label style="font-size:12px;font-weight:600;color:#0d1b2a;margin-bottom:6px;display:block;">Subject</label>
                        <input @bind="manualEmailSubject" style="width:100%;padding:8px 10px;border:1px solid #d7dee8;border-radius:7px;font-size:13px;background:#f8fafc;outline:none;" />
                    </div>
                    <div>
                        <label style="font-size:12px;font-weight:600;color:#0d1b2a;margin-bottom:6px;display:block;">Message</label>
                        <textarea @bind="manualEmailBody" rows="5" placeholder="Tulis pesan notifikasi alarm..." style="width:100%;padding:8px 10px;border:1px solid #d7dee8;border-radius:7px;font-size:13px;background:#f8fafc;outline:none;font-family:inherit;resize:vertical;box-sizing:border-box;"></textarea>
                    </div>
                </div>

                <div style="display:flex;justify-content:flex-end;margin-top:16px;">
                    <button @onclick="SendManualEmail" disabled="@(isSendingManualEmail || !emails.Any())" style="display:flex;align-items:center;gap:8px;padding:10px 16px;background:#1a73e8;color:white;border:none;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;opacity:@(isSendingManualEmail || !emails.Any() ? 0.6 : 1);">
                        <i class="bi @(isSendingManualEmail ? "bi-hourglass-split" : "bi-send")" style="font-size:14px;"></i>
                        @(isSendingManualEmail ? "Sending..." : "Send to all")
                    </button>
                </div>
            </div>
        </div>

        <div style="display:flex;align-items:center;justify-content:space-between;gap:16px;margin:4px 0 14px 0;flex-wrap:wrap;">
            <div>
                <h2 style="font-size:16px;font-weight:800;color:#0d1b2a;margin:0;">Recipients</h2>
                <p style="font-size:13px;color:#6b7a8d;margin:3px 0 0 0;">Kelola alamat email dan group penerima alarm</p>
            </div>
            <div style="display:flex;gap:8px;flex-wrap:wrap;">
                <input @bind="recipientSearch" @bind:event="oninput" placeholder="Search recipient..." style="width:220px;padding:9px 12px;border:1px solid #d7dee8;border-radius:8px;font-size:13px;background:#ffffff;outline:none;" />
                <select @bind="selectedGroupFilter" style="width:180px;padding:9px 12px;border:1px solid #d7dee8;border-radius:8px;font-size:13px;background:#ffffff;outline:none;">
                    <option value="">All groups</option>
                    <option value="__ungrouped">Not grouped</option>
                    @foreach (var item in groups)
                    {
                        <option value="@item.Id">@item.Name</option>
                    }
                </select>
            </div>
        </div>

        <div style="display:grid;grid-template-columns:minmax(420px,1fr) minmax(320px,0.7fr);gap:14px;margin-bottom:18px;">
            <EditForm Model="email" OnValidSubmit="AddEmail" style="flex:1;min-width:280px;">
                <div style="background:#ffffff;border-radius:8px;border:1px solid #d7dee8;padding:14px;box-shadow:0 1px 2px rgba(15,23,42,0.04);">
                    <div style="font-size:11px;font-weight:700;color:#6b7a8d;text-transform:uppercase;letter-spacing:0.6px;margin-bottom:12px;">
                        Add Email
                    </div>
                    <div style="display:grid;grid-template-columns:minmax(220px,1fr) 180px 130px;gap:10px;align-items:start;">
                        <div>
                            <InputText @bind-Value="email.Address"
                                       style="width:100%;padding:9px 10px;border:1px solid #d7dee8;border-radius:7px;font-size:13px;background:#f8fafc;outline:none;" 
                                       placeholder="Email address" />
                            <ValidationMessage For="@(() => email.Address)" style="font-size:11px;color:#dc2626;margin-top:4px;" />
                        </div>
                        <div>
                            <InputSelect @bind-Value="email.EmailGroupId" 
                                         style="width:100%;padding:9px 10px;border:1px solid #d7dee8;border-radius:7px;font-size:13px;background:#f8fafc;outline:none;">
                                <option value="">-- No Group --</option>
                                @foreach (var g in groups)
                                {
                                    <option value="@g.Id">@g.Name</option>
                                }
                            </InputSelect>
                        </div>
                        <button type="submit"
                                style="display:flex;align-items:center;justify-content:center;gap:6px;padding:9px 12px;background:#1a73e8;border:none;border-radius:7px;font-size:13px;font-weight:600;color:white;cursor:pointer;width:100%;">
                            <i class="bi bi-plus-lg"></i>
                            Add Email
                        </button>
                    </div>
                </div>
            </EditForm>

            <EditForm Model="group" OnValidSubmit="AddGroup" style="flex:1;min-width:240px;">
                <div style="background:#ffffff;border-radius:8px;border:1px solid #d7dee8;padding:14px;box-shadow:0 1px 2px rgba(15,23,42,0.04);">
                    <div style="font-size:11px;font-weight:700;color:#6b7a8d;text-transform:uppercase;letter-spacing:0.6px;margin-bottom:12px;">
                        Add Group
                    </div>
                    <div style="display:grid;grid-template-columns:minmax(180px,1fr) 120px;gap:10px;">
                        <div>
                            <InputText @bind-Value="group.Name"
                                       style="width:100%;padding:9px 10px;border:1px solid #d7dee8;border-radius:7px;font-size:13px;background:#f8fafc;outline:none;"
                                       placeholder="Group name" />
                            <ValidationMessage For="@(() => group.Name)" style="font-size:11px;color:#dc2626;margin-top:4px;" />
                        </div>
                        <button type="submit"
                                style="display:flex;align-items:center;justify-content:center;gap:6px;padding:9px 12px;background:#1a73e8;border:none;border-radius:7px;font-size:13px;font-weight:600;color:white;cursor:pointer;width:100%;">
                            <i class="bi bi-plus-lg"></i>
                            Add
                        </button>
                    </div>
                </div>
            </EditForm>
        </div>

        @if (isLoading)
        {
            <div style="padding:24px;text-align:center;color:#6b7a8d;font-size:13px;">Loading emails...</div>
        }
        else if (!groups.Any() && !emails.Any())
        {
            <div style="padding:28px;text-align:center;color:#6b7a8d;font-size:13px;background:#ffffff;border:1px dashed #cbd5e1;border-radius:12px;margin-bottom:20px;">
                <i class="bi bi-inbox" style="font-size:22px;color:#94a3b8;display:block;margin-bottom:8px;"></i>
                No email recipients configured
            </div>
        }
        else if (!FilteredEmails.Any())
        {
            <div style="padding:28px;text-align:center;color:#6b7a8d;font-size:13px;background:#ffffff;border:1px dashed #cbd5e1;border-radius:12px;margin-bottom:20px;">
                <i class="bi bi-search" style="font-size:22px;color:#94a3b8;display:block;margin-bottom:8px;"></i>
                No recipients match the current filter
            </div>
        }

        @foreach (var grp in groups)
        {
            var groupEmails = GetFilteredEmailsForGroup(grp.Id);

            if (!groupEmails.Any())
                continue;

            <div style="margin-bottom:18px;background:#ffffff;border:1px solid #d7dee8;border-radius:8px;overflow:hidden;">
                <div style="background:#f8fafc;border-bottom:1px solid #e2e8f0;padding:9px 12px;display:flex;align-items:center;gap:10px;">
                    <div style="flex:1;display:flex;align-items:center;gap:8px;">
                        <span style="font-size:13px;font-weight:700;color:#0d1b2a;">Group</span>
                        <span style="font-size:11px;color:#6b7a8d;background:#f1f5f9;border-radius:999px;padding:3px 8px;">@groupEmails.Count</span>
                        <InputText @bind-Value="grp.Name"
                                   disabled="@(grp.Id != editingGroupId)"
                                   style="max-width:360px;flex:1;padding:7px 10px;border:1px solid #d7dee8;border-radius:6px;font-size:12.5px;background:#ffffff;outline:none;" />
                    </div>
                    <button @onclick="() => ToggleGroupEdit(grp)"
                            title="Edit group" style="width:30px;height:30px;border:none;border-radius:6px;background:#1a73e8;color:white;display:flex;align-items:center;justify-content:center;cursor:pointer;">
                        <i class="bi @(grp.Id == editingGroupId ? "bi-check-lg" : "bi-pencil")" style="font-size:13px;"></i>
                    </button>
                    <button @onclick="() => DeleteOrCancelGroup(grp)"
                            title="Delete group" style="width:30px;height:30px;border:none;border-radius:6px;background:#ef4444;color:white;display:flex;align-items:center;justify-content:center;cursor:pointer;">
                        <i class="bi @(editingGroupId == grp.Id ? "bi-x" : "bi-trash")" style="font-size:13px;"></i>
                    </button>
                </div>

                <div style="display:grid;grid-template-columns:1fr;gap:0;">
                    @foreach (var e in groupEmails)
                    {
                        <div style="display:grid;grid-template-columns:minmax(280px,1fr) 110px;align-items:center;gap:12px;padding:9px 12px;border-bottom:1px solid #f1f5f9;">
                            <InputText @bind-Value="e.Address"
                                       disabled="@(e.Id != editingEmailId)"
                                       style="width:100%;padding:7px 9px;border:1px solid #d7dee8;border-radius:6px;font-size:12.5px;background:#f8fafc;outline:none;" />
                            <div style="display:flex;justify-content:flex-end;gap:6px;">
                                <button @onclick="() => ToggleEdit(e)"
                                        title="Edit recipient" style="width:30px;height:30px;border:none;border-radius:6px;background:#1a73e8;color:white;display:flex;align-items:center;justify-content:center;cursor:pointer;">
                                    <i class="bi @(e.Id == editingEmailId ? "bi-check-lg" : "bi-pencil")" style="font-size:13px;"></i>
                                </button>
                                <button @onclick="() => DeleteOrCancel(e)"
                                        title="Delete recipient" style="width:30px;height:30px;border:none;border-radius:6px;background:#ef4444;color:white;display:flex;align-items:center;justify-content:center;cursor:pointer;">
                                    <i class="bi @(editingEmailId == e.Id ? "bi-x" : "bi-trash")" style="font-size:13px;"></i>
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        @if(UngroupedFilteredEmails.Any())
        {
            <div style="margin-top:18px;background:#ffffff;border:1px solid #d7dee8;border-radius:8px;overflow:hidden;">
                <div style="background:#f8fafc;border-bottom:1px solid #e2e8f0;padding:9px 12px;">
                    <h3 style="font-size:14px;font-weight:800;color:#0d1b2a;margin:0;display:flex;align-items:center;gap:8px;">
                        Not Grouped
                        <span style="font-size:11px;color:#6b7a8d;background:#f1f5f9;border-radius:999px;padding:3px 8px;">@UngroupedFilteredEmails.Count</span>
                    </h3>
                </div>
                <div style="display:grid;grid-template-columns:1fr;gap:0;">
                    @foreach (var e in UngroupedFilteredEmails)
                    {
                        <div style="display:grid;grid-template-columns:minmax(280px,1fr) 110px;align-items:center;gap:12px;padding:9px 12px;border-bottom:1px solid #f1f5f9;">
                            <InputText @bind-Value="e.Address"
                                       disabled="@(e.Id != editingEmailId)"
                                       style="width:100%;padding:7px 9px;border:1px solid #d7dee8;border-radius:6px;font-size:12.5px;background:#f8fafc;outline:none;" />
                            <div style="display:flex;justify-content:flex-end;gap:6px;">
                                <button @onclick="() => ToggleEdit(e)"
                                        title="Edit recipient" style="width:30px;height:30px;border:none;border-radius:6px;background:#1a73e8;color:white;display:flex;align-items:center;justify-content:center;cursor:pointer;">
                                    <i class="bi @(e.Id == editingEmailId ? "bi-check-lg" : "bi-pencil")" style="font-size:13px;"></i>
                                </button>
                                <button @onclick="() => DeleteOrCancel(e)"
                                        title="Delete recipient" style="width:30px;height:30px;border:none;border-radius:6px;background:#ef4444;color:white;display:flex;align-items:center;justify-content:center;cursor:pointer;">
                                    <i class="bi @(editingEmailId == e.Id ? "bi-x" : "bi-trash")" style="font-size:13px;"></i>
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

@code {
    private bool isLoading = true;
    private Email email = new Email();
    private string message = string.Empty;
    private string messageType = "error";
    private List<Email> emails = new();
    private Guid? editingEmailId = null;
    private string tempEmail = string.Empty;
    private EmailGroup group = new();
    private List<EmailGroup> groups = new();
    private Guid? editingGroupId = null;
    private string tempGroup = string.Empty;
    private SetSmtp smtpSettings = new();
    private SetSmtp smtpSettingsBackup = new();
    private bool isEditingSmtp = false;
    private bool isSendingManualEmail = false;
    private string manualEmailSubject = "Alarm Notification";
    private string manualEmailBody = string.Empty;
    private string recipientSearch = string.Empty;
    private string selectedGroupFilter = string.Empty;

    private bool IsSmtpConfigured =>
        !string.IsNullOrWhiteSpace(smtpSettings.Host) &&
        smtpSettings.Port > 0 &&
        !string.IsNullOrWhiteSpace(smtpSettings.User) &&
        !string.IsNullOrWhiteSpace(smtpSettings.Pass) &&
        !string.IsNullOrWhiteSpace(smtpSettings.FromEmail);

    private List<Email> FilteredEmails => emails
        .Where(MatchesSearch)
        .Where(MatchesGroupFilter)
        .ToList();

    private List<Email> UngroupedFilteredEmails => FilteredEmails
        .Where(item => item.EmailGroupId == null)
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadPageData();
    }

    private async Task LoadPageData()
    {
        isLoading = true;

        try
        {
            emails = (await EmailRecipientService.GetEmailsAsync()).ToList();
            groups = (await EmailRecipientService.GetGroupsAsync()).ToList();
            smtpSettings = await SmtpSettingsService.GetSettingsAsync();
        }
        catch (Exception)
        {
            ShowMessage("Failed to load email settings", "error");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task AddEmail()
    {
        var result = await EmailRecipientService.AddEmailAsync(email);

        if (!result.Success)
        {
            ShowMessage(result.ErrorMessage ?? "Failed to add email", "error");
            return;
        }

        email = new Email();
        ClearMessage();
        await LoadPageData();
    }

    private List<Email> GetFilteredEmailsForGroup(Guid groupId)
    {
        return FilteredEmails
            .Where(item => item.EmailGroupId == groupId)
            .ToList();
    }

    private bool MatchesSearch(Email item)
    {
        return string.IsNullOrWhiteSpace(recipientSearch) ||
               item.Address.Contains(recipientSearch, StringComparison.OrdinalIgnoreCase);
    }

    private bool MatchesGroupFilter(Email item)
    {
        if (string.IsNullOrWhiteSpace(selectedGroupFilter))
            return true;

        if (selectedGroupFilter == "__ungrouped")
            return item.EmailGroupId == null;

        return Guid.TryParse(selectedGroupFilter, out var groupId) && item.EmailGroupId == groupId;
    }

    private async Task DeleteOrCancel(Email selectedEmail)
    {
        if (editingEmailId == selectedEmail.Id)
        {
            editingEmailId = null;
            selectedEmail.Address = tempEmail;
        }
        else
        {
            await EmailRecipientService.DeleteEmailAsync(selectedEmail.Id);
            await LoadPageData();
        }
    }

    private async Task ToggleEdit(Email selectedEmail)
    {
        if (editingEmailId == selectedEmail.Id)
        {
            var result = await EmailRecipientService.UpdateEmailAsync(selectedEmail);

            if (!result.Success)
            {
                ShowMessage(result.ErrorMessage ?? "Failed to update email", "error");
                return;
            }

            editingEmailId = null;
            ClearMessage();
            await LoadPageData();
        }
        else
        {
            if (editingEmailId != null)
            {
                var prev = emails.First(x => x.Id == editingEmailId);
                prev.Address = tempEmail;
            }

            editingEmailId = selectedEmail.Id;
            tempEmail = selectedEmail.Address;
        }
    }

    private async Task AddGroup()
    {
        var result = await EmailRecipientService.AddGroupAsync(group);

        if (!result.Success)
        {
            ShowMessage(result.ErrorMessage ?? "Failed to add group", "error");
            return;
        }

        group = new EmailGroup();
        ClearMessage();
        await LoadPageData();
    }

    private async Task ToggleGroupEdit(EmailGroup selectedGroup)
    {
        if (editingGroupId == selectedGroup.Id)
        {
            var result = await EmailRecipientService.UpdateGroupAsync(selectedGroup);

            if (!result.Success)
            {
                ShowMessage(result.ErrorMessage ?? "Failed to update group", "error");
                return;
            }

            editingGroupId = null;
            tempGroup = string.Empty;
            ClearMessage();
            await LoadPageData();
        }
        else
        {
            if (editingGroupId != null)
            {
                var prev = groups.First(x => x.Id == editingGroupId);
                prev.Name = tempGroup;
            }

            editingGroupId = selectedGroup.Id;
            tempGroup = selectedGroup.Name;
        }
    }

    private async Task DeleteOrCancelGroup(EmailGroup selectedGroup)
    {
        if (editingGroupId == selectedGroup.Id)
        {
            editingGroupId = null;
            selectedGroup.Name = tempGroup;
        }
        else
        {
            await EmailRecipientService.DeleteGroupAsync(selectedGroup.Id);
            await LoadPageData();
        }
    }

    private void BeginSmtpEdit()
    {
        smtpSettingsBackup = smtpSettings.Clone();
        isEditingSmtp = true;
        ClearMessage();
    }

    private void CancelSmtpEdit()
    {
        smtpSettings = smtpSettingsBackup.Clone();
        isEditingSmtp = false;
    }

    private async Task SaveSmtpSettings()
    {
        try
        {
            await SmtpSettingsService.SaveSettingsAsync(smtpSettings);
            isEditingSmtp = false;
            ShowMessage("SMTP settings saved", "success");
        }
        catch (Exception)
        {
            ShowMessage("Failed to save SMTP settings", "error");
        }
    }

    private async Task SendManualEmail()
    {
        if (string.IsNullOrWhiteSpace(manualEmailBody))
        {
            ShowMessage("Message cannot be empty", "error");
            return;
        }

        var recipients = emails.Select(item => item.Address).Where(address => !string.IsNullOrWhiteSpace(address)).ToList();

        if (!recipients.Any())
        {
            ShowMessage("No email recipients configured", "error");
            return;
        }

        isSendingManualEmail = true;

        try
        {
            await EmailService.SendBulkEmailAsync(recipients, manualEmailSubject, manualEmailBody);
            manualEmailBody = string.Empty;
            ShowMessage($"Email sent to {recipients.Count} recipient(s)", "success");
        }
        catch (Exception)
        {
            ShowMessage("Failed to send email", "error");
        }
        finally
        {
            isSendingManualEmail = false;
        }
    }

    private void ShowMessage(string value, string type)
    {
        message = value;
        messageType = type;
    }

    private void ClearMessage()
    {
        message = string.Empty;
        messageType = "error";
    }
}
